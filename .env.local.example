# Forge OS — environment template. Copy to .env.local and fill in.
# Every var is read somewhere in the app; empty optional vars degrade to a
# real, branded "not configured" state instead of crashing.

# ============================================================================
# App
# ============================================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ============================================================================
# Supabase — REQUIRED. Auth (Google OAuth) + the primary Postgres data store.
# Project Settings -> API. Enable the Google provider under Authentication ->
# Providers, and add your domain(s) to Authentication -> URL Configuration.
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ============================================================================
# Chat provider — REQUIRED for the assistant. Server-only.
# ============================================================================
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL=""

# ============================================================================
# Legacy Firebase Storage fallback — OPTIONAL (old binary blobs only; sign-in
# no longer uses Firebase).
# ============================================================================
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
FIREBASE_ADMIN_PROJECT_ID=""
FIREBASE_ADMIN_CLIENT_EMAIL=""
FIREBASE_ADMIN_PRIVATE_KEY=""

# ============================================================================
# Media & tools — OPTIONAL feature-by-feature.
# ============================================================================
SILICONFLOW_API_KEY=""        # image generation
GEMINI_API_KEY=""             # vision / scanned-document analysis
SERPER_API_KEY=""             # web search (primary)
BRAVE_SEARCH_API_KEY=""       # web search (fallback)
OPENAI_API_KEY=""             # voice output (TTS)
GROQ_API_KEY=""               # voice input (transcription)
E2B_API_KEY=""                # code execution sandbox

# ============================================================================
# Stripe billing — OPTIONAL.
# ============================================================================
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID=""
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=""
NEXT_PUBLIC_STRIPE_MAX_PRICE_ID=""
NEXT_PUBLIC_STRIPE_ULTRA_PRICE_ID=""

# ============================================================================
# Debug switches — OPTIONAL.
# ============================================================================
# NEXT_PUBLIC_FORGE_INSPECTOR="1"   # exposes the instruction inspector
# FORGE_RATE_LIMIT_PER_WINDOW="60"  # per-user chat requests / minute
